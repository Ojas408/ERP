# Copy to .env and edit before hosting

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=erp_db

# Backend
JWT_SECRET=change_this_to_a_long_random_secret
NODE_ENV=production
SEED_DB=true
CORS_ORIGIN=*

# Ports exposed on host
HTTP_PORT=80
API_PORT=5000
DB_PORT=5432
