// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String   @id @default(uuid())
  name             String
  stripeCustomerId String?
  subscriptionPlan String   @default("free") // free, pro, enterprise
  status           String   @default("active") // active, suspended
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users              User[]
  productions        Production[]
  inventories        Inventory[]
  expenses           Expense[]
  sites              Site[]
  maintenances       Maintenance[]
  employees          Employee[]
  attendances        Attendance[]
  vehicles           Vehicle[]
  consumptions       Consumption[]
  vendors            Vendor[]
  purchaseOrders     PurchaseOrder[]
  challans           Challan[]
  vehicleMovements   VehicleMovement[]
  documents          Document[]
  auditLogs          AuditLog[]
  departments        Department[]
  materialCategories MaterialCategory[]
  vehicleTypes       VehicleType[]
  expenseCategories  ExpenseCategory[]
  unitsOfMeasure     UnitOfMeasure[]
  materialInwards    MaterialInward[]
  rmcGrades          RMCGrade[]
  scraps             Scrap[]
  overheadEntries    OverheadEntry[]
  customColumns      CustomColumn[]
  customData         Json?
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("user") // admin, manager, user
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Production {
  id              String   @id @default(uuid())
  date            DateTime @default(now())
  amount          Float
  unit            String   @default("tons")
  grade           String? // RMC grade: M20, M25, M30 etc.
  productionType  String? // Slab, Column, Transit Mixture, Foundation, etc.
  siteId          String?
  site            Site?    @relation(fields: [siteId], references: [id])
  notes           String?
  quality         String?
  towerName       String? // Building / tower / slab reference
  isRejected      Boolean  @default(false)
  rejectionReason String?
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Inventory {
  id           String   @id @default(uuid())
  itemName     String
  quantity     Float
  unit         String
  minThreshold Float    @default(0)
  price        Float?
  category     String?
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Expense {
  id            String   @id @default(uuid())
  date          DateTime @default(now())
  category      String
  amount        Float
  description   String?
  paymentStatus String   @default("paid") // paid, pending
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Site {
  id              String           @id @default(uuid())
  name            String
  location        String?
  status          String           @default("active") // active, completed, on-hold
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  productions     Production[]
  consumptions    Consumption[]
  vehicles        Vehicle[]
  materialInwards MaterialInward[]
  scraps          Scrap[]
  overheadEntries OverheadEntry[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Maintenance {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  type        String // Routine, Repair, Breakdown
  cost        Float
  description String?
  status      String   @default("completed") // completed, pending
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Employee {
  id           String       @id @default(uuid())
  employeeCode String?
  name         String
  position     String
  department   String?
  designation  String?
  contact      String?
  salary       Float
  status       String       @default("active") // active, inactive
  joinedDate   DateTime     @default(now())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  attendances  Attendance[]
  documents    Document[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Attendance {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  hoursWorked Float
  overtime    Float    @default(0)
  status      String   @default("present") // present, absent, leave
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Vehicle {
  id           String            @id @default(uuid())
  plateNumber  String
  model        String
  status       String            @default("available") // available, in-use, maintenance
  lastService  DateTime?
  vehicleType  String?
  driver       String?
  siteId       String?
  site         Site?             @relation(fields: [siteId], references: [id])
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  maintenances Maintenance[]
  challans     Challan[]
  movements    VehicleMovement[]
  documents    Document[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([plateNumber, tenantId])
}

model Consumption {
  id              String   @id @default(uuid())
  date            DateTime @default(now())
  material        String
  amount          Float
  unit            String
  siteId          String?
  site            Site?    @relation(fields: [siteId], references: [id])
  isRejected      Boolean  @default(false)
  rejectionReason String?
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Vendor {
  id             String          @id @default(uuid())
  name           String
  contact        String?
  category       String?
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PurchaseOrder {
  id          String   @id @default(uuid())
  orderNumber String
  date        DateTime @default(now())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  totalAmount Float
  status      String   @default("pending") // pending, received, cancelled
  items       String? // JSON string or summary
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orderNumber, tenantId])
}

model Challan {
  id            String     @id @default(uuid())
  challanNumber String
  date          DateTime   @default(now())
  vehicleId     String
  vehicle       Vehicle    @relation(fields: [vehicleId], references: [id])
  material      String
  quantity      Float
  destination   String
  status        String     @default("pending") // pending, approved, dispatched, delivered
  tenantId      String
  tenant        Tenant     @relation(fields: [tenantId], references: [id])
  documents     Document[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([challanNumber, tenantId])
}

model VehicleMovement {
  id           String    @id @default(uuid())
  vehicleId    String
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id])
  fromLocation String
  toLocation   String
  startTime    DateTime
  endTime      DateTime?
  distance     Float?
  fuelConsumed Float?
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Master Data Models
model Department {
  id       String @id @default(uuid())
  name     String
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}

model MaterialCategory {
  id       String @id @default(uuid())
  name     String
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}

model VehicleType {
  id       String @id @default(uuid())
  name     String
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}

model ExpenseCategory {
  id       String @id @default(uuid())
  name     String
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}

model UnitOfMeasure {
  id       String @id @default(uuid())
  name     String
  code     String
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}

// Local File Uploads Model
model Document {
  id           String   @id @default(uuid())
  fileName     String
  originalName String
  fileType     String
  filePath     String
  fileSize     Int
  uploadedAt   DateTime @default(now())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  vehicleId  String?
  vehicle    Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  challanId  String?
  challan    Challan?  @relation(fields: [challanId], references: [id], onDelete: Cascade)
}

// Global Activity logs
model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  details   String?
  userId    String
  userEmail String
  timestamp DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model MaterialInward {
  id            String   @id @default(uuid())
  inwardNumber  String
  date          DateTime @default(now())
  materialName  String
  quantity      Float
  unit          String
  supplierName  String
  vehicleNumber String?
  challanNumber String?
  siteId        String
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  receivedBy    String?
  remarks       String?
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([inwardNumber, tenantId])
}

model RMCGrade {
  id               String   @id @default(uuid())
  grade            String // M20, M25, M30, M35 etc.
  mixRatio         String? // e.g. 1:1.5:3
  cementContent    Float? // in kg/m3
  waterCementRatio Float? // e.g. 0.45
  admixture        String? // e.g. superplasticizer
  description      String?
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([grade, tenantId])
}

model Scrap {
  id           String   @id @default(uuid())
  date         DateTime @default(now())
  materialType String // Steel, Concrete, Wood etc.
  quantity     Float
  unit         String // tons, kg, units
  siteId       String?
  site         Site?    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  saleStatus   String   @default("stored") // stored, sold, disposed
  saleValue    Float?
  buyerName    String?
  remarks      String?
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OverheadEntry {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  category    String // Transit Mixture, Slabs, Cement, Aggregate, Labour, Fuel, Maintenance, Other
  description String?
  quantity    Float?
  unit        String? // cum, sqm, bags, tons, trips
  amount      Float
  siteId      String?
  site        Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  customData  Json?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CustomColumn {
  id        String   @id @default(uuid())
  entity    String
  name      String
  key       String
  type      String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
}
